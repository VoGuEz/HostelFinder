<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.LoginController"
      prefWidth="1000" prefHeight="680" styleClass="root-container">

    <VBox styleClass="left-panel" prefWidth="420" alignment="CENTER" spacing="20">
        <VBox alignment="CENTER" spacing="10">
            <Label text="🏠" styleClass="brand-icon"/>
            <Label text="HostelFinder" styleClass="brand-title"/>
            <Label text="Your home away from home" styleClass="brand-subtitle"/>
        </VBox>
        <VBox alignment="CENTER" spacing="15" style="-fx-padding: 40 30 0 30;">
            <VBox styleClass="feature-item" spacing="5">
                <Label text="🔍  Search Available Rooms" styleClass="feature-title"/>
                <Label text="Browse hundreds of student hostels near your campus" styleClass="feature-desc" wrapText="true"/>
            </VBox>
            <VBox styleClass="feature-item" spacing="5">
                <Label text="📅  Book Instantly" styleClass="feature-title"/>
                <Label text="Secure your room in just a few clicks" styleClass="feature-desc" wrapText="true"/>
            </VBox>
            <VBox styleClass="feature-item" spacing="5">
                <Label text="⭐  Verified Hostels" styleClass="feature-title"/>
                <Label text="All hostels are verified and rated by students" styleClass="feature-desc" wrapText="true"/>
            </VBox>
        </VBox>
    </VBox>

    <VBox styleClass="right-panel" prefWidth="580" alignment="CENTER">
        <VBox styleClass="form-card" spacing="24" alignment="CENTER">
            <VBox spacing="6" alignment="CENTER">
                <Label text="Welcome Back" styleClass="form-title"/>
                <Label text="Sign in to your account" styleClass="form-subtitle"/>
            </VBox>
            <VBox spacing="18" prefWidth="360">
                <VBox spacing="6">
                    <Label text="Email Address" styleClass="field-label"/>
                    <TextField fx:id="emailField" promptText="Enter your email" styleClass="text-field"/>
                </VBox>
                <VBox spacing="6">
                    <HBox>
                        <Label text="Password" styleClass="field-label" HBox.hgrow="ALWAYS"/>
                        <Button text="Forgot password?" styleClass="link-btn" onAction="#goToForgotPassword" style="-fx-font-size: 11px;"/>
                    </HBox>
                    <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="text-field"/>
                </VBox>
                <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true"/>
                <Button fx:id="loginBtn" text="Sign In" styleClass="primary-btn"
                        onAction="#handleLogin" prefWidth="360" prefHeight="48"/>
                <HBox alignment="CENTER" spacing="10">
                    <Line endX="140" styleClass="divider-line"/>
                    <Label text="or" styleClass="divider-text"/>
                    <Line endX="140" styleClass="divider-line"/>
                </HBox>
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Don't have an account?" styleClass="switch-text"/>
                    <Button text="Create Account" styleClass="link-btn" onAction="#goToRegister"/>
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</HBox>
