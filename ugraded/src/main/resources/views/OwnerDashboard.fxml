<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.OwnerDashboardController"
            prefWidth="1000" prefHeight="680" styleClass="dashboard-root">
    <top>
        <HBox styleClass="navbar" prefHeight="65" alignment="CENTER_LEFT" spacing="20">
            <Label text="🏠 HostelFinder" styleClass="nav-brand"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="🏨 My Hostels" styleClass="nav-btn" onAction="#showMyHostels"/>
            <Button text="📋 My Bookings" styleClass="nav-btn" onAction="#showMyBookings"/>
            <Button text="➕ Add Hostel" styleClass="nav-btn" onAction="#showAddHostelDialog"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="userGreeting" styleClass="nav-user"/>
            <Button text="Logout" styleClass="logout-btn" onAction="#handleLogout"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="16" style="-fx-padding: 24;">
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox fx:id="contentArea" spacing="16" style="-fx-padding: 4;"/>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
