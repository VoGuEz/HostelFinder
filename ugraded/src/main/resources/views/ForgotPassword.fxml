<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ForgotPasswordController"
      prefWidth="1000" prefHeight="680" styleClass="root-container">

    <VBox styleClass="left-panel" prefWidth="420" alignment="CENTER" spacing="20">
        <Label text="🏠" styleClass="brand-icon"/>
        <Label text="HostelFinder" styleClass="brand-title"/>
        <Label text="Your home away from home" styleClass="brand-subtitle"/>
    </VBox>

    <VBox styleClass="right-panel" prefWidth="580" alignment="CENTER">
        <VBox styleClass="form-card" spacing="24" alignment="CENTER">

            <!-- Step 1: Enter Email -->
            <VBox fx:id="emailStep" spacing="18" prefWidth="360">
                <VBox spacing="6" alignment="CENTER">
                    <Label text="🔒" style="-fx-font-size: 40px;"/>
                    <Label text="Forgot Password?" styleClass="form-title"/>
                    <Label text="Enter your email to receive a reset code" styleClass="form-subtitle" wrapText="true" textAlignment="CENTER"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Email Address" styleClass="field-label"/>
                    <TextField fx:id="emailField" promptText="Enter your email" styleClass="text-field"/>
                </VBox>
                <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true"/>
                <Label fx:id="successLabel" styleClass="success-label" text="" wrapText="true"/>
                <Button fx:id="sendOtpBtn" text="Send Reset Code" styleClass="primary-btn"
                        onAction="#handleSendOTP" prefWidth="360" prefHeight="48"/>
                <Button text="Back to Login" styleClass="link-btn" onAction="#goToLogin"/>
            </VBox>

            <!-- Step 2: Enter OTP + New Password -->
            <VBox fx:id="resetStep" spacing="14" prefWidth="360" visible="false" managed="false">
                <VBox spacing="6" alignment="CENTER">
                    <Label text="Reset Password" styleClass="form-title"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="OTP Code" styleClass="field-label"/>
                    <TextField fx:id="otpField" promptText="Enter 6-digit code" styleClass="text-field"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="New Password" styleClass="field-label"/>
                    <PasswordField fx:id="newPasswordField" promptText="New password" styleClass="text-field"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Confirm New Password" styleClass="field-label"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Repeat new password" styleClass="text-field"/>
                </VBox>
                <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true"/>
                <Label fx:id="successLabel" styleClass="success-label" text="" wrapText="true"/>
                <Button fx:id="resetBtn" text="Reset Password" styleClass="primary-btn"
                        onAction="#handleResetPassword" prefWidth="360" prefHeight="48"/>
            </VBox>

        </VBox>
    </VBox>
</HBox>
